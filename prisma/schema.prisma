generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Degree {
  id           String @id @default(uuid())
  name         String
  totalCredits Float
  categories   RequirementCategory[]
}

model RequirementCategory {
  id              String @id @default(uuid())
  name            String
  requiredCredits Float
  degreeId        String
  degree          Degree @relation(fields: [degreeId], references: [id])
  courses         Course[] @relation("CategoryCourses")
}

model Course {
  id          String @id @default(uuid())
  code        String @unique
  name        String
  credits     Float
  categories  RequirementCategory[] @relation("CategoryCourses")
  userCourses UserCourse[]
}

model UserCourse {
  id          String @id @default(uuid())
  courseCode  String
  courseName  String
  credits     Float
  grade       Float?
  semester    String?
  course      Course? @relation(fields: [courseCode], references: [code])
}
